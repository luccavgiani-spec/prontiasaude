# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# GTM Server-Side Tagging (Optional Fallback)
# Get this URL from your GTM Server Container:
# 1. Access https://tagmanager.google.com/
# 2. Go to your Server container (e.g., prontasaude-sgtm)
# 3. Click on "Preview" or check container settings
# 4. Copy the default tagging server URL (e.g., https://your-container-id.appspot.com)
# This is used as fallback while custom domain SSL is being provisioned
VITE_GTM_SERVER_URL="https://your-gtm-server.appspot.com"

# Google Apps Script Proxy (via Supabase Edge Function)
# This is the Supabase function that proxies requests to GAS
VITE_GAS_BASE="https://ploqujuhpwutpcibedbr.supabase.co/functions/v1/gas-proxy"

